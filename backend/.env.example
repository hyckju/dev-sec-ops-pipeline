DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mirae_naeil
SECRET_KEY=your-secret-key-here
# CI/CD 인증용 API 키. 비워두면 인증 비활성화(개발/검증).
# 값을 설정하면 /api/v1/pipelines/* 호출 시 X-API-Key 헤더로 동일 값을 요구.
API_KEY=
NVD_API_KEY=your-nvd-api-key-here
WORKSPACE_DIR=/tmp/mirae_naeil_workspaces
SEMGREP_TIMEOUT=300
